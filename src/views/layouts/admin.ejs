<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %><%= appName %></title>
  <link rel="stylesheet" href="/public/admin.css">
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="brand">
        <h1><%= appName %></h1>
      </div>
      <nav>
        <a href="/admin" class="<%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>">Dashboard</a>
        <a href="/admin/users" class="<%= typeof active !== 'undefined' && active === 'users' ? 'active' : '' %>">Users</a>
        <a href="/admin/system-templates" class="<%= typeof active !== 'undefined' && active === 'system-templates' ? 'active' : '' %>">System Templates</a>
      </nav>
      <form action="/admin/logout" method="POST" class="logout-form">
        <button type="submit" class="btn btn-ghost">Đăng xuất</button>
      </form>
    </aside>

    <main class="main">
      <% if (typeof flash !== 'undefined' && flash) { %>
        <div class="flash flash-<%= flash.type || 'info' %>">
          <%- flash.message %>
        </div>
      <% } %>
      <%- body %>
    </main>
  </div>
</body>
</html>
