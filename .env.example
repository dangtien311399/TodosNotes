PORT=3000
NODE_ENV=development

# ============================================================
# Turso (libSQL) — bắt buộc TURSO_DATABASE_URL
# ============================================================
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token-here

# ============================================================
# JWT secrets — random ≥16 ký tự, MỖI secret KHÁC NHAU
# Sinh nhanh: `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`
# ============================================================
# JWT cho mobile API (người dùng cuối)
JWT_SECRET=change-this-to-random-long-string-min-16-chars

# JWT cho admin web — tách biệt để có thể revoke độc lập
JWT_ADMIN_SECRET=change-this-to-DIFFERENT-random-long-string

# Cookie sign secret — random ≥32 ký tự
COOKIE_SECRET=another-random-string-at-least-32-characters-long-please

# ============================================================
# Admin login
# ============================================================
# Tên đăng nhập admin (free-form, không cần là email)
ADMIN_USERNAME=admin

# Bcrypt hash của mật khẩu admin.
# Cách sinh:
#   1) Chọn mật khẩu mạnh (>=8 ký tự, có chữ hoa + số + ký tự đặc biệt)
#   2) Chạy: npm run admin:hash -- "MatKhauCuaBan!23"
#   3) Copy NGUYÊN dòng `ADMIN_PASSWORD_HASH=$2b$12$...` vào file này
#   4) Trên Render: Settings → Environment → thêm biến tương ứng (KHÔNG commit .env)
ADMIN_PASSWORD_HASH=$2b$12$replace-with-output-of-npm-run-admin-hash

# ============================================================
# Push notifications / Firebase Cloud Messaging
# ============================================================
# Scheduler mặc định tắt để môi trường dev/test không cần Firebase.
# Bật trên server chạy worker/API chính:
NOTIFICATIONS_ENABLED=false

# Đường dẫn tuyệt đối hoặc tương đối tới Firebase service account JSON.
# Không commit file JSON này.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
